rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // ============================================
    // Helper Functions
    // ============================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated()
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'platform_admin';
    }

    function isMallOwner(mallId) {
      return isAuthenticated()
        && firestore.get(/databases/(default)/documents/malls/$(mallId)).data.ownerId == request.auth.uid;
    }

    function isImageType() {
      return request.resource.contentType.matches('image/.*');
    }

    function isUnderMaxImageSize() {
      return request.resource.size <= 5 * 1024 * 1024; // 5MB
    }

    function isUnderMaxFileSize() {
      return request.resource.size <= 10 * 1024 * 1024; // 10MB
    }

    // ============================================
    // Product Images - Mall owner can write, public read
    // ============================================

    match /products/{mallId}/{allPaths=**} {
      allow read: if true;
      allow write: if isMallOwner(mallId)
        && isImageType()
        && isUnderMaxImageSize();
    }

    // ============================================
    // Mall Assets (logo, favicon, etc.) - Mall owner can write, public read
    // ============================================

    match /malls/{mallId}/{allPaths=**} {
      allow read: if true;
      allow write: if isMallOwner(mallId)
        && isUnderMaxFileSize();
    }

    // ============================================
    // User Files (profile images, etc.) - Owner can write, public read
    // ============================================

    match /users/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if isAuthenticated()
        && request.auth.uid == userId
        && isUnderMaxFileSize();
    }

    // ============================================
    // Platform Banners - Admin only write, public read
    // ============================================

    match /banners/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin()
        && isImageType()
        && isUnderMaxImageSize();
    }

    // ============================================
    // Supplier Documents (사업자등록증 등) - Supplier owner can write, admin can read
    // ============================================

    match /suppliers/{supplierId}/{allPaths=**} {
      allow read: if isAdmin()
        || (isAuthenticated() && request.auth.uid == supplierId);
      allow write: if isAuthenticated()
        && request.auth.uid == supplierId
        && isUnderMaxFileSize();
    }

    // ============================================
    // Reports & PDFs (정산서, 세금계산서) - Generated by Cloud Functions
    // ============================================

    match /reports/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if false; // Cloud Functions only
    }

    // ============================================
    // Excel Templates & Uploads - Authenticated users
    // ============================================

    match /excel/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated()
        && isUnderMaxFileSize();
    }
  }
}
